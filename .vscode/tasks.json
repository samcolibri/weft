{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Local Server",
      "type": "shell",
      "command": "./dev.sh server 2>&1 | tee weft-logs.txt",
      "options": { "cwd": "${workspaceFolder}" },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": { "group": "dev-local", "reveal": "always" }
    },
    {
      "label": "Local Dashboard",
      "type": "shell",
      "command": "./dev.sh dashboard",
      "options": { "cwd": "${workspaceFolder}" },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": { "group": "dev-local", "reveal": "always" }
    },
    {
      "label": "Dev Local All",
      "dependsOn": ["Local Server", "Local Dashboard"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    }
  ]
}
